    ctx.fillStyle='#003087';ctx.fillRect(bx+s*.2,by+s*.35,s*.6,s*.38);
    ctx.fillRect(bx+s*.06,by+s*.38,s*.16,s*.3);ctx.fillRect(bx+s*.78,by+s*.38,s*.16,s*.3);
    ctx.fillStyle='#0040B0';ctx.fillRect(bx+s*.2,by+s*.35,s*.6,3);ctx.fillRect(bx+s*.2,by+s*.35,3,s*.38);
    ctx.fillStyle='rgba(0,0,0,0.28)';ctx.fillRect(bx+s*.56,by+s*.36,s*.24,s*.36);
    // Red accent stripe — RIGHT arm (front-facing arm for right-facing char)
    ctx.fillStyle='#E31837';ctx.fillRect(bx+s*.78,by+s*.38,3,s*.28);
    // Domino's logo patch on left chest
    ctx.fillStyle='#fff';ctx.fillRect(bx+s*.24,by+s*.42,s*.2,s*.12);
    ctx.fillStyle='#E31837';ctx.fillRect(bx+s*.26,by+s*.44,4,4);ctx.fillRect(bx+s*.32,by+s*.44,3,3);
    ctx.fillRect(bx+s*.35,by+s*.46,2,2);
    // Delivery bag on RIGHT side (in front for right-facing character)
    const bagSwing=isWalking?Math.sin(t*0.018+1)*3:0;
    ctx.fillStyle='#001f5c';ctx.fillRect(bx+s*.8+bagSwing,by+s*.38,8,s*.28);
    ctx.fillStyle='#E31837';ctx.fillRect(bx+s*.8+bagSwing,by+s*.38,8,4);
    ctx.fillStyle='#fff';ctx.fillRect(bx+s*.81+bagSwing,by+s*.4,6,2);
    // Belt
    ctx.fillStyle='#111';ctx.fillRect(bx+s*.2,by+s*.68,s*.6,3);
    ctx.fillStyle='#888';ctx.fillRect(bx+s*.46,by+s*.68,8,4);
    // Head
    ctx.fillStyle='rgba(0,0,0,0.65)';ctx.fillRect(bx+s*.27,by+s*.08,s*.46,s*.32);
    ctx.fillStyle='#FFCBA0';ctx.fillRect(bx+s*.29,by+s*.1,s*.42,s*.28);
    ctx.fillStyle='rgba(0,0,0,0.18)';ctx.fillRect(bx+s*.52,by+s*.1,s*.19,s*.28);
    // Domino's cap with brim on RIGHT (front of right-facing character)
    ctx.fillStyle='#003087';ctx.fillRect(bx+s*.25,by+s*.06,s*.5,8);
    ctx.fillStyle='#001f5c';ctx.fillRect(bx+s*.25,by+s*.06,s*.5,3);
    ctx.fillStyle='#E31837';ctx.fillRect(bx+s*.66,by+s*.09,s*.18,4); // brim RIGHT = front
    ctx.fillStyle='#fff';ctx.fillRect(bx+s*.44,by+s*.07,6,4);
    // 5 o'clock stubble
