function calcStats(p){const c=CLS[p.cls],pb=p.pb||{};let str=c.str,int=c.int,dex=c.dex,vit=c.vit,luk=c.luk;let atk=pb.atk||0,def=pb.def||0,mgk=pb.mgk||0,mhp=pb.mhp||0;let ls=pb.ls||0,crit=pb.crit||0,dodge=pb.dodge||0,regen=pb.regen||0,thorns=pb.thorns||0;Object.values(p.eq).forEach(it=>{if(!it)return;str+=it.str||0;int+=it.int||0;dex+=it.dex||0;vit+=it.vit||0;luk+=it.luk||0;atk+=it.atk||0;def+=it.def||0;mgk+=it.mgk||0;mhp+=it.mhp||0;ls+=it.ls||0;crit+=it.crit||0;});(p.buffs||[]).forEach(b=>{str+=b.str||0;dex+=b.dex||0;atk+=b.atk||0;});if(p.status?.frozen)def=Math.round(def*.5);const totalMhp=c.bhp+vit*5+mhp+p.lv*8;const berserk=pb.berserk&&p.hp<totalMhp*.25;return{atk:atk+str*1.5+p.lv*2+(berserk?pb.berserk:0),def:def+(vit*.5|0)+p.lv,mgk:mgk+int*1.5,mhp:totalMhp,ls,crit:Math.min(.65,crit+dex*.015+luk*.01),dodge:Math.min(.5,dodge+dex*.01),regen,thorns,str,dex,vit,luk,int,vis:VR+(pb.vis||0)};}
function applyStatusToPlayer(p,type,power){const s={...(p.status||{})};if(type==='poison'){s.poison=4;s.poisonDmg=power||6;}if(type==='burn'){s.burn=3;s.burnDmg=power||8;}if(type==='freeze'){s.frozen=2;}return{...p,status:s};}
function applyStatusToEnemy(e,type){const s={...(e.status||{})};if(type==='poison'){s.poison=4;s.poisonDmg=8;}if(type==='burn'){s.burn=3;s.burnDmg=10;}if(type==='freeze'){s.frozen=2;}return{...e,status:s};}
