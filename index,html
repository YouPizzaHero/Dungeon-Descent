    ctx.fillStyle='#1a1a28';ctx.fillRect(bx+s*.29,lly,s*.2,s*.22);ctx.fillRect(bx+s*.52,rly,s*.2,s*.22);
    ctx.fillStyle='#111118';ctx.fillRect(bx+s*.29,lly,s*.2,3);ctx.fillRect(bx+s*.52,rly,s*.2,3);
    // Body — clean heathered navy henley, elevated casual
    ctx.fillStyle='rgba(0,0,0,0.6)';ctx.fillRect(bx+s*.16,by+s*.33,s*.68,s*.4);
    ctx.fillRect(bx+s*.02,by+s*.36,s*.18,s*.3);ctx.fillRect(bx+s*.8,by+s*.36,s*.18,s*.3);
    ctx.fillStyle='#2a3a5c';ctx.fillRect(bx+s*.18,by+s*.35,s*.64,s*.38);
    ctx.fillRect(bx+s*.04,by+s*.38,s*.16,s*.28);ctx.fillRect(bx+s*.8,by+s*.38,s*.16,s*.28);
    ctx.fillStyle='#3a4a6c';ctx.fillRect(bx+s*.18,by+s*.35,s*.64,3);ctx.fillRect(bx+s*.18,by+s*.35,3,s*.38);
    ctx.fillStyle='rgba(0,0,0,0.22)';ctx.fillRect(bx+s*.56,by+s*.35,s*.26,s*.36);
