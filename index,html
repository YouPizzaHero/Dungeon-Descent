  const h=th(wx,wy);
  // Dark base
  ctx.fillStyle=WALL_FACE;
  ctx.fillRect(x,y,s,s);

  // Brick face (slightly lighter)
  const brickCol=WALL_BRICK[h%3];
  ctx.fillStyle=brickCol;
  // Two brick rows, staggered
  const bh=Math.round(s*.48);
  ctx.fillRect(x+1,y+1,s-2,bh-1);
  ctx.fillRect(x+1,y+bh+1,s-2,s-bh-2);

  // Mortar lines
  ctx.fillStyle=WALL_MORTAR;
  ctx.fillRect(x,y+bh,s,2);       // horizontal mortar
  ctx.fillRect(x,y,1,s);          // left edge mortar
  ctx.fillRect(x+s-1,y,1,s);      // right edge mortar
  ctx.fillRect(x,y,s,1);          // top edge
  ctx.fillRect(x,y+s-1,s,1);      // bottom edge

  // Staggered vertical mortar (brick pattern)
  const row=wy%2;
  const vx=row?Math.round(s*.5):Math.round(s*.5);
  ctx.fillStyle=WALL_MORTAR;
  ctx.fillRect(x+Math.round(s*.5),y+1,1,bh-1);
  ctx.fillRect(x+Math.round(s*(row?.25:.75)),y+bh+1,1,s-bh-2);

  // Top highlight: light hits the top of the wall
  ctx.fillStyle=WALL_TOP_HI;
  ctx.fillRect(x+1,y+1,s-2,2);
  ctx.fillRect(x+1,y+bh+1,s-2,2);

  // Right+bottom shadow: wall face in shadow
  ctx.fillStyle=WALL_SHADOW;
  ctx.fillRect(x+s-2,y+1,2,s-2);
  ctx.fillRect(x+1,y+s-2,s-2,2);

  // Occasional crack/chip detail
  if(h%12===0){
    ctx.fillStyle=WALL_MORTAR;
    const cx2=(h>>6)%(s-6)+3;
    ctx.fillRect(x+cx2,y+4,2,4);ctx.fillRect(x+cx2-1,y+5,1,2);
  }
}

function drawTorchSconce(ctx,x,y,s){
  const t=Date.now()*0.004,fx=x+s*.5,fy=y+s*.44;
  ctx.fillStyle='#2a1408';ctx.fillRect(x+s*.36,y+s*.52,s*.28,s*.09);
  ctx.fillStyle='#4a2810';ctx.fillRect(x+s*.42,y+s*.5,s*.16,s*.16);
  ctx.fillStyle='#3a2008';ctx.fillRect(x+s*.38,y+s*.58,s*.24,s*.07);
  const fw=4.5+Math.sin(t*6.1+x)*1.8+Math.cos(t*4.3+y)*1.2;
  const fh=10+Math.sin(t*5.3+y)*2.5+Math.cos(t*7.1+x)*2;
  const ox=Math.sin(t*3.7)*1.5;
  ctx.save();ctx.globalAlpha=0.85;
  ctx.fillStyle='rgba(255,80,5,1)';ctx.beginPath();ctx.ellipse(fx+ox,fy,fw,fh,Math.sin(t*3)*0.18,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(255,170,20,0.95)';ctx.beginPath();ctx.ellipse(fx+ox*.7,fy+1,fw*.7,fh*.72,Math.sin(t*4)*0.12,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(255,230,120,0.95)';ctx.beginPath();ctx.ellipse(fx+ox*.3,fy+2,fw*.42,fh*.48,0,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(255,250,220,0.9)';ctx.beginPath();ctx.ellipse(fx,fy+3,fw*.2,fh*.28,0,0,Math.PI*2);ctx.fill();
  ctx.globalAlpha=1;
  for(let i=0;i<4;i++){
    const st=t*4+i*1.57;
    const spx=fx+Math.sin(st+i)*fw*.9,spy=fy-Math.abs(Math.sin(st*1.4))*fh*.8;
    if(Math.sin(st+i*0.7)>0){ctx.fillStyle='rgba(255,200,60,0.7)';ctx.fillRect(spx,spy,1.5,1.5);}
  }
  ctx.restore();
}

function drawAO(ctx,dg,camX,camY,s,tiX,tiY){
  for(let ty=0;ty<tiY;ty++)for(let tx=0;tx<tiX;tx++){
    const wx=camX+tx,wy=camY+ty;
    if(wx<0||wx>=DW||wy<0||wy>=DH)continue;
    if(dg.vis[wy][wx]!==V.LIT||dg.tiles[wy][wx]!==T.FLOOR)continue;
    const sx=(wx-camX)*s,sy=(wy-camY)*s;
    if(dg.tiles[wy-1]?.[wx]===T.WALL){const g=ctx.createLinearGradient(sx,sy,sx,sy+s*.55);g.addColorStop(0,'rgba(0,0,0,0.55)');g.addColorStop(1,'rgba(0,0,0,0)');ctx.fillStyle=g;ctx.fillRect(sx,sy,s,s*.55);}
    if(dg.tiles[wy]?.[wx-1]===T.WALL){const g=ctx.createLinearGradient(sx,sy,sx+s*.5,sy);g.addColorStop(0,'rgba(0,0,0,0.38)');g.addColorStop(1,'rgba(0,0,0,0)');ctx.fillStyle=g;ctx.fillRect(sx,sy,s*.5,s);}
    if(dg.tiles[wy]?.[wx+1]===T.WALL){const g=ctx.createLinearGradient(sx+s,sy,sx+s*.5,sy);g.addColorStop(0,'rgba(0,0,0,0.38)');g.addColorStop(1,'rgba(0,0,0,0)');ctx.fillStyle=g;ctx.fillRect(sx+s*.5,sy,s*.5,s);}
    if(dg.tiles[wy+1]?.[wx]===T.WALL){const g=ctx.createLinearGradient(sx,sy+s,sx,sy+s*.5);g.addColorStop(0,'rgba(0,0,0,0.28)');g.addColorStop(1,'rgba(0,0,0,0)');ctx.fillStyle=g;ctx.fillRect(sx,sy+s*.5,s,s*.5);}
  }
}

function drawGame(ctx,state){
  const{dg,pos,p}=state,s=TS;
  ctx.fillStyle='#010106';ctx.fillRect(0,0,canvasW,canvasH);
  const camX=pos.x-(canvasW/2/s|0),camY=pos.y-(canvasH/2/s|0);
  const tiX=Math.ceil(canvasW/s)+3,tiY=Math.ceil(canvasH/s)+3;
  const t=Date.now()*0.001;
  const psx=(pos.x-camX)*s,psy=(pos.y-camY)*s;
  const flicker=Math.sin(t*2.1)*3+Math.cos(t*3.7)*2+Math.sin(t*1.3)*2;

  for(let ty=0;ty<tiY;ty++)for(let tx=0;tx<tiX;tx++){
    const wx=camX+tx,wy=camY+ty;
    if(wx<0||wx>=DW||wy<0||wy>=DH)continue;
    const vis=dg.vis[wy][wx];if(vis===V.DARK)continue;
    const sx=(wx-camX)*s,sy=(wy-camY)*s,dim=vis===V.SEEN?0.45:1;
    ctx.save();ctx.globalAlpha=dim;
    const tile=dg.tiles[wy][wx];
    if(tile===T.FLOOR||tile===T.CHEST||tile===T.STAIRS||tile===T.MERCHANT){
      drawStoneFloor(ctx,sx,sy,s,wx,wy,dim);
    }else if(tile===T.WALL){drawStoneWall(ctx,sx,sy,s,wx,wy);}
    if(tile===T.STAIRS&&vis===V.LIT){
      const sg=ctx.createRadialGradient(sx+s/2,sy+s/2,2,sx+s/2,sy+s/2,s*.72);
      sg.addColorStop(0,'rgba(0,180,255,0.5)');sg.addColorStop(0.5,'rgba(0,120,220,0.22)');sg.addColorStop(1,'rgba(0,60,180,0)');
      ctx.fillStyle=sg;ctx.fillRect(sx,sy,s,s);
      ctx.fillStyle='#0a3555';for(let i=0;i<4;i++)ctx.fillRect(sx+5+i*2,sy+6+i*4,s-10-i*4,3);
      ctx.fillStyle='rgba(0,210,255,0.6)';for(let i=0;i<4;i++)ctx.fillRect(sx+5+i*2,sy+6+i*4,s-10-i*4,1);
      ctx.fillStyle='rgba(0,230,255,0.95)';ctx.font=`bold ${s*.44|0}px monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.strokeStyle='rgba(0,40,80,0.9)';ctx.lineWidth=2;ctx.strokeText('▼',sx+s/2,sy+s*.64);ctx.fillText('▼',sx+s/2,sy+s*.64);
    }
    if(tile===T.CHEST&&vis===V.LIT){
      const cg=ctx.createRadialGradient(sx+s/2,sy+s/2,2,sx+s/2,sy+s/2,s*.65);
      cg.addColorStop(0,'rgba(255,200,50,0.28)');cg.addColorStop(1,'rgba(200,120,0,0)');
      ctx.fillStyle=cg;ctx.fillRect(sx,sy,s,s);
      ctx.fillStyle='#4a2008';ctx.fillRect(sx+3,sy+9,s-6,s-12);
      ctx.fillStyle='#6a3010';ctx.fillRect(sx+3,sy+9,s-6,5);
      ctx.fillStyle='#8B6914';ctx.fillRect(sx+3,sy+13,s-6,2);
      ctx.fillStyle='#C8A030';[[3,9],[s-6,9],[3,s-5],[s-6,s-5]].forEach(([dx,dy])=>ctx.fillRect(sx+dx,sy+dy,3,3));
      ctx.fillStyle='#FFD700';ctx.fillRect(sx+s/2-3,sy+11,6,5);ctx.fillStyle='#805000';ctx.fillRect(sx+s/2-1,sy+13,2,3);
    }
    if(tile===T.MERCHANT&&vis===V.LIT){
      const mg=ctx.createRadialGradient(sx+s/2,sy+s/2,2,sx+s/2,sy+s/2,s*.6);
      mg.addColorStop(0,'rgba(255,210,60,0.32)');mg.addColorStop(1,'rgba(200,120,0,0)');
      ctx.fillStyle=mg;ctx.fillRect(sx+2,sy+2,s-4,s-4);
      ctx.fillStyle='#FFD700';ctx.font=`bold ${s*.52|0}px monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.strokeStyle='rgba(60,30,0,0.9)';ctx.lineWidth=2;ctx.strokeText('$',sx+s/2,sy+s*.56);ctx.fillText('$',sx+s/2,sy+s*.56);
      ctx.strokeStyle='#AA8800';ctx.lineWidth=1;ctx.strokeRect(sx+2,sy+2,s-4,s-4);
    }
    ctx.restore();

  }

  drawAO(ctx,dg,camX,camY,s,tiX,tiY);

  for(let ty=0;ty<tiY;ty++)for(let tx=0;tx<tiX;tx++){
    const wx=camX+tx,wy=camY+ty;
    if(wx<0||wx>=DW||wy<0||wy>=DH)continue;
    if(dg.vis[wy][wx]!==V.LIT||dg.tiles[wy][wx]!==T.WALL||dg.tiles[wy+1]?.[wx]!==T.FLOOR)continue;
    if(th(wx,wy)%100<22)drawTorchSconce(ctx,(wx-camX)*s,(wy-camY)*s,s);
  }

  dg.items.forEach(it=>{
    if(dg.vis[it.y]?.[it.x]!==V.LIT)return;
    const sx=(it.x-camX)*s,sy=(it.y-camY)*s;
    if(sx>-s&&sx<canvasW+s&&sy>-s&&sy<canvasH+s)drawFloorItem(ctx,it,sx,sy,s);
  });
  dg.enemies.forEach(e=>{
    if(e.hp<=0||dg.vis[e.y]?.[e.x]!==V.LIT)return;
    const sx=(e.x-camX)*s,sy=(e.y-camY)*s;
    if(sx>-s&&sx<canvasW+s&&sy>-s&&sy<canvasH+s)drawEnemy(ctx,e,sx,sy,s);
  });
  drawPlayer(ctx,psx,psy,s,p.cls);

  // Subtle player warmth (very small, not a spotlight)
  const pwg=ctx.createRadialGradient(psx+s/2,psy+s/2,0,psx+s/2,psy+s/2,s*2.2+flicker*.4);
  pwg.addColorStop(0,'rgba(255,200,100,0.11)');pwg.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle=pwg;ctx.fillRect(psx-s*3,psy-s*3,s*7,s*7);
  // Screen-edge vignette (not player-centered — just darkens the screen borders)
  const vg=ctx.createRadialGradient(canvasW/2,canvasH/2,Math.min(canvasW,canvasH)*0.42,canvasW/2,canvasH/2,Math.max(canvasW,canvasH)*0.75);
  vg.addColorStop(0,'rgba(0,0,0,0)');vg.addColorStop(0.65,'rgba(0,0,0,0.22)');vg.addColorStop(1,'rgba(0,0,0,0.72)');
  ctx.fillStyle=vg;ctx.fillRect(0,0,canvasW,canvasH);

  (state.floats||[]).forEach(f=>{
    const fx=(f.x-camX)*s+s/2,fy=(f.y-camY)*s-4;
    if(fx<-30||fx>canvasW+30||fy<-30||fy>canvasH+30)return;
    ctx.font='bold 15px monospace';ctx.fillStyle=f.col||'#FFF';ctx.textAlign='center';
    ctx.strokeStyle='rgba(0,0,0,0.9)';ctx.lineWidth=3;ctx.strokeText(f.txt,fx,fy);ctx.fillText(f.txt,fx,fy);
  });
  const ps=p.status||{};let si=0;
  if(ps.poison>0){ctx.fillStyle='#CC44CC';ctx.fillRect(psx+si*10,psy-12,8,6);si++;}
  if(ps.burn>0){ctx.fillStyle='#FF6600';ctx.fillRect(psx+si*10,psy-12,8,6);si++;}
  if(ps.frozen>0){ctx.fillStyle='#44AAFF';ctx.fillRect(psx+si*10,psy-12,8,6);si++;}
  drawMinimap(ctx,dg,pos);
}

function drawMinimap(ctx,dg,pos){
  const mw=110,mh=110,mx=canvasW-mw-6,my=6;
  const sx=mw/DW,sy=mh/DH;
  ctx.fillStyle='rgba(2,2,8,0.88)';ctx.fillRect(mx-1,my-1,mw+2,mh+2);
  ctx.strokeStyle='#1a1a44';ctx.lineWidth=1;ctx.strokeRect(mx-1,my-1,mw+2,mh+2);
  for(let y=0;y<DH;y++)for(let x=0;x<DW;x++){
    const v=dg.vis[y][x];if(v===V.DARK)continue;
    const tt=dg.tiles[y][x],lit=v===V.LIT;
    if(tt===T.WALL)ctx.fillStyle=lit?'#1c1c3a':'#0e0e1e';
    else ctx.fillStyle=lit?'#2a2a50':'#161630';
    ctx.fillRect(mx+x*sx,my+y*sy,Math.max(1,sx-.3),Math.max(1,sy-.3));
    if(lit){
      if(tt===T.STAIRS){ctx.fillStyle='#00CFFF';ctx.fillRect(mx+x*sx,my+y*sy,Math.max(2,sx),Math.max(2,sy));}
      if(tt===T.MERCHANT){ctx.fillStyle='#FFD700';ctx.fillRect(mx+x*sx,my+y*sy,Math.max(2,sx),Math.max(2,sy));}
      if(tt===T.CHEST){ctx.fillStyle='#FF9000';ctx.fillRect(mx+x*sx,my+y*sy,Math.max(2,sx),Math.max(2,sy));}
    }
  }
  dg.enemies.forEach(e=>{
    if(e.hp<=0||dg.vis[e.y]?.[e.x]!==V.LIT)return;
    ctx.fillStyle=e.boss?'#FF1144':'#FF4455';
    ctx.fillRect(mx+e.x*sx-0.5,my+e.y*sy-0.5,Math.max(2.5,sx+1),Math.max(2.5,sy+1));
  });
  ctx.fillStyle='#FFE040';ctx.fillRect(mx+pos.x*sx-1.5,my+pos.y*sy-1.5,Math.max(3,sx+3),Math.max(3,sy+3));
  ctx.strokeStyle='#33334a';ctx.lineWidth=0.5;ctx.strokeRect(mx-1,my-1,mw+2,mh+2);
}

function drawPlayer(ctx,x,y,s,cls){
  const t=Date.now();
  const msSinceMove=t-PANIM.lastMove,msSinceAtk=t-PANIM.lastAtk,msSinceHurt=t-PANIM.lastHurt;
  const isWalking=msSinceMove<220,isAtking=msSinceAtk<280,isHurt=msSinceHurt<320;

  const breathOff=isWalking?0:Math.round(Math.sin(t*0.0025)*1.2);
  const walkCycle=Math.sin(t*0.018);
  const walkBob=isWalking?Math.round(walkCycle*2.5):0;
  const footSwing=isWalking?Math.round(walkCycle*3.5):0;
  const atkT=Math.max(0,1-msSinceAtk/280);
  const atkLean=isAtking?Math.round(Math.sin(atkT*Math.PI)*4*PANIM.facing):0;
  const atkRecoil=isAtking?Math.round(Math.sin(atkT*Math.PI)*-2):0;

  const by=y+breathOff+walkBob+atkRecoil,bx=x+atkLean;

  ctx.save();
  if(PANIM.facing===-1){ctx.translate(bx+s/2,by+s/2);ctx.scale(-1,1);ctx.translate(-(bx+s/2),-(by+s/2));}

