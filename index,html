function drawLargeMap(ctx,dg,pos,floor){
  const PAD=12;
  const mw=canvasW-PAD*2,mh=canvasH-PAD*2;
  const mx=PAD,my=PAD;
  ctx.fillStyle='rgba(3,3,10,0.94)';
  ctx.fillRect(0,0,canvasW,canvasH);
  ctx.strokeStyle='#2a2a55';ctx.lineWidth=1.5;
  ctx.strokeRect(mx,my,mw,mh);
  const sx=mw/DW,sy=mh/DH;
  for(let y=0;y<DH;y++)for(let x=0;x<DW;x++){
    const v=dg.vis[y][x];if(v===V.DARK)continue;
    const t=dg.tiles[y][x],lit=v===V.LIT;
    if(t===T.WALL)ctx.fillStyle=lit?'#1c1c3a':'#0e0e1e';
    else ctx.fillStyle=lit?'#28284e':'#161630';
    ctx.fillRect(mx+x*sx,my+y*sy,Math.max(1,sx-.3),Math.max(1,sy-.3));
    if(lit){
      if(t===T.STAIRS){const g=ctx.createRadialGradient(mx+x*sx+sx/2,my+y*sy+sy/2,0,mx+x*sx+sx/2,my+y*sy+sy/2,sx*2);g.addColorStop(0,'#00CFFF');g.addColorStop(1,'rgba(0,150,255,0)');ctx.fillStyle=g;ctx.fillRect(mx+x*sx-sx,my+y*sy-sy,sx*3,sy*3);ctx.fillStyle='#00EFFF';ctx.fillRect(mx+x*sx,my+y*sy,sx,sy);}
      if(t===T.CHEST){ctx.fillStyle='#FF9900';ctx.fillRect(mx+x*sx,my+y*sy,sx,sy);}
      if(t===T.MERCHANT){ctx.fillStyle='#FFD700';ctx.fillRect(mx+x*sx,my+y*sy,sx,sy);}
    }
  }
  dg.items.forEach(it=>{
    if(dg.vis[it.y]?.[it.x]!==V.LIT)return;
    ctx.fillStyle=it.rc||'#aaa';
    ctx.fillRect(mx+it.x*sx,my+it.y*sy,Math.max(2,sx),Math.max(2,sy));
  });
  dg.enemies.forEach(e=>{
    if(e.hp<=0||dg.vis[e.y]?.[e.x]!==V.LIT)return;
    ctx.fillStyle=e.boss?'#FF1144':'#FF3344';
    const ex=mx+e.x*sx,ey=my+e.y*sy;
    ctx.fillRect(ex-1,ey-1,sx+2,sy+2);
    if(e.boss){ctx.strokeStyle='#FF1144';ctx.lineWidth=1;ctx.strokeRect(ex-2,ey-2,sx+4,sy+4);}
  });
  const px=mx+pos.x*sx,py=my+pos.y*sy;
  const pg=ctx.createRadialGradient(px+sx/2,py+sy/2,0,px+sx/2,py+sy/2,sx*3);
  pg.addColorStop(0,'rgba(255,240,60,0.4)');pg.addColorStop(1,'rgba(255,200,0,0)');
  ctx.fillStyle=pg;ctx.fillRect(px-sx*2,py-sy*2,sx*5,sy*5);
  ctx.fillStyle='#FFE040';ctx.fillRect(px-1,py-1,sx+2,sy+2);
  ctx.fillStyle='#FFF';ctx.fillRect(px,py,Math.max(2,sx*.6),Math.max(2,sy*.6));
  ctx.font='bold 13px monospace';ctx.fillStyle='#4a4a88';ctx.textAlign='center';
  ctx.fillText(`FLOOR ${floor} — DUNGEON MAP   [M to close]`,canvasW/2,my-3);
  const legend=[['#FFE040','You'],['#FF3344','Enemy'],['#FF1144','Boss'],['#00EFFF','Stairs'],['#FF9900','Chest'],['#FFD700','Shop']];
  let lx=mx;
  legend.forEach(([col,label])=>{
    ctx.fillStyle=col;ctx.fillRect(lx,my+mh+4,10,10);
    ctx.fillStyle='#666';ctx.font='10px monospace';ctx.textAlign='left';
    ctx.fillText(label,lx+13,my+mh+13);lx+=label.length*7+22;
  });
}

