{n:'Strength Brew',str:3,dur:8},{n:'Speed Potion',dex:4,dur:8},{n:'Scroll of Fire',mdmg:55},{n:'Antidote',cure:true},{n:'Full Restore',hp:9999},{n:'Freeze Scroll',freeze:3},{n:'Poison Flask',poison:4,pdmg:8}]};
