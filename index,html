        cell.innerHTML=`<div style="font-size:18px;">${icon}</div><div><div style="font-size:9px;color:${C.textMuted};letter-spacing:.5px;">${n.toUpperCase()}</div><div style="font-size:16px;font-weight:bold;color:${C.textPrimary};">${v}</div></div>`;
        grid.appendChild(cell);
      });
      sec.appendChild(grid);scr.appendChild(sec);
    });

    // Talents
    const talLabel=document.createElement('div');
    talLabel.style.cssText=`font-size:10px;font-weight:bold;color:#bb88ff;letter-spacing:2px;margin-bottom:8px;padding-left:8px;border-left:2.5px solid #9966cc;`;
    talLabel.textContent='PASSIVE TALENTS';scr.appendChild(talLabel);
    const pb=p.pb||{};
    const pbKeys=Object.keys(pb).filter(k=>pb[k]&&k!=='execBonus'&&k!=='vis'&&k!=='berserk');
    if(pbKeys.length||pb.execBonus||p.goldMult>1){
      const pills=document.createElement('div');pills.style.cssText='display:flex;flex-wrap:wrap;gap:5px;';
      const labelMap={mhp:`Max HP +${pb.mhp}`,regen:`Regen +${pb.regen}`,def:`DEF +${pb.def}`,atk:`ATK +${pb.atk}`,ls:`Lifesteal +${Math.round((pb.ls||0)*100)}%`,crit:`Crit +${Math.round((pb.crit||0)*100)}%`,dodge:`Dodge +${Math.round((pb.dodge||0)*100)}%`,thorns:`Thorns ${Math.round((pb.thorns||0)*100)}%`,mgk:`MGK +${pb.mgk}`};
      pbKeys.forEach(k=>{
        const pill=document.createElement('div');
        pill.style.cssText=`font-size:10px;background:#1e1030;border:1px solid #6644aa;border-radius:6px;padding:5px 11px;color:#cc99ff;font-weight:bold;`;
        pill.textContent=labelMap[k]||k;pills.appendChild(pill);
      });
      if(pb.execBonus){const ep=document.createElement('div');ep.style.cssText=`font-size:10px;background:#1e1030;border:1px solid #6644aa;border-radius:6px;padding:5px 11px;color:#cc99ff;font-weight:bold;`;ep.textContent='Death Mark';pills.appendChild(ep);}
      if(p.goldMult>1){const gp=document.createElement('div');gp.style.cssText=`font-size:10px;background:#1e1600;border:1px solid ${C.gold};border-radius:6px;padding:5px 11px;color:${C.goldBright};font-weight:bold;`;gp.textContent=`Gold ×${p.goldMult.toFixed(1)}`;pills.appendChild(gp);}
      scr.appendChild(pills);
    }else{
      const no=document.createElement('div');
      no.style.cssText=`color:${C.textMuted};font-size:11px;`;
      no.textContent='No talents yet — level up to gain passive abilities.';scr.appendChild(no);
    }
    body.appendChild(scr);
  }

  div.appendChild(body);root.appendChild(div);
}

function renderMerchant(root,st){const{p,dg}=st;const div=document.createElement('div');div.style.cssText='display:flex;flex-direction:column;height:100%;background:#07030a;';const hdr=document.createElement('div');hdr.style.cssText='padding:10px 14px;background:#0a0512;border-bottom:1px solid #2a1a2a;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;';hdr.innerHTML=`<div><div style="color:#FFD700;font-weight:bold;font-size:15px;">THE WANDERING MERCHANT</div><div style="color:#664444;font-size:9px;margin-top:2px;">"Finest wares in the dungeon."</div></div><div style="text-align:right;"><div style="color:#FFD700;font-size:14px;font-weight:bold;">${p.gold}g</div></div>`;const closeBtn=document.createElement('button');closeBtn.textContent='LEAVE';closeBtn.style.cssText='display:block;margin-top:4px;background:none;border:1px solid #444;border-radius:5px;color:#888;padding:3px 8px;cursor:pointer;font-family:monospace;font-size:10px;';closeBtn.addEventListener('click',()=>dispatch({type:'CLOSE_MERCHANT'}));hdr.querySelector('div:last-child').appendChild(closeBtn);div.appendChild(hdr);const body=document.createElement('div');body.style.cssText='flex:1;overflow-y:auto;padding:10px;';body.innerHTML+='<div style="font-size:10px;color:#664444;margin-bottom:8px;letter-spacing:1px;">FOR SALE</div>';if(!dg.merchantInv?.length){body.innerHTML+='<div style="color:#333;font-size:11px;">Sold out!</div>';}(dg.merchantInv||[]).forEach((it,i)=>{const cost=Math.round((it.val||20)*2);const canAfford=p.gold>=cost;const card=document.createElement('div');card.style.cssText=`padding:8px 10px;margin-bottom:7px;border-radius:6px;background:#110a0a;border:1px solid ${it.rc}44;display:flex;justify-content:space-between;align-items:center;`;const sl=[it.atk?`ATK+${it.atk}`:null,it.def?`DEF+${it.def}`:null,it.mgk?`MGK+${it.mgk}`:null,it.mhp?`MaxHP+${it.mhp}`:null,it.hp?`Heals ${it.hp}`:null].filter(Boolean).join(' ');card.innerHTML=`<div style="flex:1;min-width:0;"><div style="font-size:11px;color:${it.rc};font-weight:bold;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${it.dn}</div><div style="font-size:10px;color:#111;margin-top:2px;font-weight:600;">${it.rn} ${it.type}${sl?' - '+sl:''}</div></div><button style="padding:5px 8px;border:none;border-radius:5px;background:${canAfford?'#4A3010':'#1a1a1a'};color:${canAfford?'#FFD700':'#444'};font-size:10px;cursor:${canAfford?'pointer':'default'};font-family:monospace;margin-left:8px;white-space:nowrap;">${cost}g</button>`;card.querySelector('button').addEventListener('click',()=>{if(canAfford)dispatch({type:'BUY',i});});body.appendChild(card);});body.innerHTML+='<div style="font-size:10px;color:#664444;margin:12px 0 8px;letter-spacing:1px;border-top:1px solid #1a1a30;padding-top:10px;">SELL ITEMS</div>';if(!p.inv.length)body.innerHTML+='<div style="color:#333;font-size:11px;">Nothing to sell</div>';p.inv.forEach((it,i)=>{const val=Math.max(1,Math.round((it.val||10)/2));const card=document.createElement('div');card.style.cssText='padding:7px 10px;margin-bottom:5px;border-radius:6px;background:#0a0a0a;border:1px solid #1a1a1a;display:flex;justify-content:space-between;align-items:center;';card.innerHTML=`<div style="flex:1;min-width:0;font-size:10px;color:${it.rc||'#AAA'};overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${it.dn}</div><button style="padding:4px 7px;border:none;border-radius:4px;background:#1E3A1E;color:#6aaa6a;font-size:10px;cursor:pointer;font-family:monospace;margin-left:8px;white-space:nowrap;">+${val}g</button>`;card.querySelector('button').addEventListener('click',()=>dispatch({type:'SELL',i}));body.appendChild(card);});div.appendChild(body);root.appendChild(div);}
function renderTalent(root,st){const talents=st.pendingTalents||pickTalents();const div=document.createElement('div');div.style.cssText='display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:20px;background:#030312;';div.innerHTML=`<div style="font-size:10px;color:#444;letter-spacing:3px;margin-bottom:10px;">LEVEL UP</div><div style="font-size:22px;color:#FFD700;font-weight:bold;margin-bottom:6px;">Level ${st.p.lv}!</div><div style="font-size:12px;color:#888;margin-bottom:22px;">Choose a talent:</div>`;talents.forEach(t=>{const btn=document.createElement('div');btn.style.cssText='width:100%;max-width:300px;padding:14px 16px;margin-bottom:10px;border-radius:8px;background:#0e0e24;border:1px solid #2a2a55;cursor:pointer;';btn.innerHTML=`<div style="font-size:14px;color:#DDAAFF;font-weight:bold;margin-bottom:4px;">${t.n}</div><div style="font-size:11px;color:#778;line-height:1.5;">${t.d}</div>`;btn.addEventListener('click',()=>dispatch({type:'PICK_TALENT',talent:t}));btn.addEventListener('mouseenter',()=>{btn.style.background='#161640';btn.style.borderColor='#5555AA';});btn.addEventListener('mouseleave',()=>{btn.style.background='#0e0e24';btn.style.borderColor='#2a2a55';});div.appendChild(btn);});root.appendChild(div);}
function renderDeath(root,st){const{p,floor,log}=st;const div=document.createElement('div');div.style.cssText='display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;background:#0a0005;padding:24px;';div.innerHTML=`<div style="font-size:50px;margin-bottom:10px;opacity:.8;">X</div><div style="font-size:24px;color:#CC0000;font-weight:bold;margin-bottom:7px;letter-spacing:2px;">YOU DIED</div><div style="font-size:12px;color:#666;margin-bottom:6px;">${p.name} the ${CLS[p.cls].n} fell on floor ${floor}</div><div style="font-size:11px;color:#444;margin-bottom:18px;">Level ${p.lv} | ${p.xp} XP | ${p.gold} gold</div><div style="max-width:280px;font-size:9px;color:#333;text-align:center;line-height:1.8;margin-bottom:24px;border:1px solid #1a0010;border-radius:7px;padding:10px;">${log.slice(0,5).join('<br>')}</div><button id="retry" style="padding:11px 32px;background:#CC0000;border:none;border-radius:7px;color:#fff;font-size:14px;font-weight:bold;cursor:pointer;font-family:monospace;">TRY AGAIN</button>`;root.appendChild(div);div.querySelector('#retry').addEventListener('click',()=>dispatch({type:'RESTART'}));}
document.addEventListener('keydown',e=>{if(document.activeElement&&document.activeElement.tagName==='INPUT')return;const km={ArrowUp:{type:'MOVE',dx:0,dy:-1},ArrowDown:{type:'MOVE',dx:0,dy:1},ArrowLeft:{type:'MOVE',dx:-1,dy:0},ArrowRight:{type:'MOVE',dx:1,dy:0},w:{type:'MOVE',dx:0,dy:-1},s:{type:'MOVE',dx:0,dy:1},a:{type:'MOVE',dx:-1,dy:0},d:{type:'MOVE',dx:1,dy:0},q:{type:'SKILL'},i:{type:'TOGGLE_INV'},' ':{type:'MOVE',dx:0,dy:0},z:{type:'MOVE',dx:0,dy:0},Enter:{type:'DISMISS'}};const act=km[e.key];if(act){e.preventDefault();dispatch(act);}if(e.key==='m'||e.key==='M'){e.preventDefault();showMap=!showMap;}});
document.addEventListener('touchmove',e=>e.preventDefault(),{passive:false});
setInterval(()=>{if(GS.scr===S.GAME)dispatch({type:'ENEMY_TICK'});},600);
(function flickerLoop(){
  if(GS.scr===S.GAME&&canvasW>0&&canvas.parentNode){
    const ctx=canvas.getContext('2d');ctx.imageSmoothingEnabled=false;
    drawGame(ctx,GS);
    if(showMap)drawLargeMap(ctx,GS.dg,GS.pos,GS.floor);
  }
  requestAnimationFrame(flickerLoop);
})();
render();
