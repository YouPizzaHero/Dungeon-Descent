function pickRar(f){const w=[...RW];const b=Math.floor(f/4);w[0]=Math.max(8,w[0]-b*5);w[1]+=b;w[2]+=b;w[3]+=Math.floor(b/2);w[4]+=Math.floor(b/3);let t=w.reduce((a,b)=>a+b,0),r=Math.random()*t;for(let i=0;i<w.length;i++){r-=w[i];if(r<=0)return i;}return 0;}
function mkItem(f,ft=null){const type=ft||(Math.random()<0.2?'consumable':pick(['weapon','armor','helmet','boots','gloves','ring','amulet']));const base={...pick(BASES[type])};const id=Math.random();if(type==='consumable')return{...base,type,id,rar:0,rc:RCOLS[0],dn:base.n};const rar=pickRar(f),mult=[1,1.35,1.75,2.3,3.2][rar],fs=1+f*0.07;const item={...base,type,id,rar,rc:RCOLS[rar],rn:RARS[rar]};STATKEYS.forEach(k=>{if(item[k]&&typeof item[k]==='number')item[k]=Math.max(1,Math.round(item[k]*mult*fs));});let pfx=null,sfx=null;if(rar>=1)pfx=pick(PFX);if(rar>=2)sfx=pick(SFX);if(rar>=4){pfx=pick(PFX);sfx=pick(SFX);}if(pfx){item.pfx=pfx.n;Object.keys(pfx).filter(k=>k!=='n').forEach(k=>{item[k]=(item[k]||0)+Math.round(pfx[k]*fs);});}if(sfx){item.sfx=sfx.n;Object.keys(sfx).filter(k=>k!=='n').forEach(k=>{item[k]=(item[k]||0)+Math.round(sfx[k]*fs);});}item.dn=[item.pfx,item.n,item.sfx].filter(Boolean).join(' ');item.val=Math.round((10+(item.atk||0)*2+(item.def||0)*2+(item.mgk||0)*2)*mult*fs);return item;}
const EDEFS=[{n:'Rat',col:'#8B6914',hp:8,atk:2,def:0,xp:4,mf:1,sp:'rat'},{n:'Goblin',col:'#5D8A4E',hp:16,atk:4,def:1,xp:10,mf:1,sp:'goblin'},{n:'Skeleton',col:'#C8C8C8',hp:22,atk:6,def:2,xp:15,mf:1,sp:'skeleton'},{n:'Orc',col:'#4A7340',hp:42,atk:10,def:4,xp:30,mf:3,sp:'orc'},{n:'Dark Mage',col:'#9400D3',hp:32,atk:14,def:2,xp:38,mf:4,sp:'dmage',statusAtk:'burn',atkChance:.35},{n:'Troll',col:'#4B6B35',hp:85,atk:16,def:7,xp:60,mf:6,sp:'troll'},{n:'Vampire',col:'#8B0000',hp:65,atk:19,def:5,xp:78,mf:8,sp:'vampire',statusAtk:'drain',atkChance:.4},{n:'Demon',col:'#CC3300',hp:105,atk:24,def:9,xp:115,mf:10,sp:'demon',statusAtk:'burn',atkChance:.45},{n:'Lich',col:'#7B00C4',hp:130,atk:28,def:12,xp:155,mf:13,sp:'lich',statusAtk:'freeze',atkChance:.4},{n:'Dragon',col:'#B22222',hp:220,atk:38,def:18,xp:300,mf:17,sp:'dragon',statusAtk:'burn',atkChance:.5}];
function mkEnemy(f){const el=EDEFS.filter(e=>e.mf<=f);const w=el.map(e=>Math.max(1,15-Math.abs(e.mf-f)*1.5));let t=w.reduce((a,b)=>a+b,0),r=Math.random()*t,ci=0;for(let i=0;i<w.length;i++){r-=w[i];if(r<=0){ci=i;break;}}const d=el[ci],sc=1+(f-1)*0.18;return{...d,id:Math.random(),mhp:Math.round(d.hp*sc),hp:Math.round(d.hp*sc),atk:Math.round(d.atk*sc),def:Math.round(d.def*sc),xp:Math.round(d.xp*sc),status:{},aggroed:false,patrolTimer:rnd(1,4),patrolDx:0,patrolDy:0};}
function mkBoss(f){const keys=Object.keys(BOSSES).map(Number).sort((a,b)=>a-b);const bk=keys.find(k=>k===f)||keys[keys.length-1];const bd={...BOSSES[bk]};const sc=1+Math.max(0,f-bk)*0.25;return{...bd,id:Math.random(),mhp:Math.round(bd.hp*sc),hp:Math.round(bd.hp*sc),atk:Math.round(bd.atk*sc),def:Math.round(bd.def*sc),xp:Math.round(bd.xp*sc),boss:true,status:{}};}
function mkDungeon(f){const isBossFloor=f%5===0;const isMerchantFloor=f%3===0&&!isBossFloor;const tiles=Array.from({length:DH},()=>new Array(DW).fill(T.WALL));const vis=Array.from({length:DH},()=>new Array(DW).fill(V.DARK));const rooms=[];function bsp(x1,y1,x2,y2,d){const w=x2-x1,h=y2-y1;if(w<9||h<9||d<=0){const rw=rnd(4,Math.min(w-2,11)),rh=rnd(4,Math.min(h-2,10));if(rw<3||rh<3)return null;const rx=x1+rnd(1,Math.max(1,w-rw-1)),ry=y1+rnd(1,Math.max(1,h-rh-1));const room={x:rx,y:ry,w:rw,h:rh,cx:rx+(rw/2|0),cy:ry+(rh/2|0)};rooms.push(room);for(let dy=ry;dy<ry+rh;dy++)for(let dx=rx;dx<rx+rw;dx++)if(dy>0&&dy<DH-1&&dx>0&&dx<DW-1)tiles[dy][dx]=T.FLOOR;return room;}const sh=w>h?Math.random()<0.6:Math.random()<0.4;let a,b;if(sh&&w>12){const s=rnd((w*.4)|0,(w*.6)|0);a=bsp(x1,y1,x1+s,y2,d-1);b=bsp(x1+s,y1,x2,y2,d-1);}else if(h>12){const s=rnd((h*.4)|0,(h*.6)|0);a=bsp(x1,y1,x2,y1+s,d-1);b=bsp(x1,y1+s,x2,y2,d-1);}else return bsp(x1,y1,x2,y2,0);if(a&&b){let cx=a.cx,cy=a.cy;while(cx!==b.cx){if(cx>=1&&cx<DW-1&&cy>=1&&cy<DH-1)tiles[cy][cx]=T.FLOOR;cx+=cx<b.cx?1:-1;}while(cy!==b.cy){if(cx>=1&&cx<DW-1&&cy>=1&&cy<DH-1)tiles[cy][cx]=T.FLOOR;cy+=cy<b.cy?1:-1;}}return a||b;}bsp(0,0,DW,DH,4);if(!rooms.length){for(let y=2;y<DH-2;y++)for(let x=2;x<DW-2;x++)tiles[y][x]=T.FLOOR;rooms.push({x:2,y:2,w:DW-4,h:DH-4,cx:DW/2|0,cy:DH/2|0});}const sh=[...rooms].sort(()=>Math.random()-.5);const sr=sh[0],er=sh[sh.length-1];tiles[er.cy][er.cx]=T.STAIRS;const enemies=[];if(isBossFloor){const boss=mkBoss(f);boss.x=er.cx;boss.y=er.cy-1;if(tiles[boss.y]?.[boss.x]===T.FLOOR)enemies.push(boss);}sh.slice(1,-1).forEach(r=>{if(Math.random()<0.3){const cx=r.x+rnd(1,r.w-2),cy=r.y+rnd(1,r.h-2);if(tiles[cy][cx]===T.FLOOR)tiles[cy][cx]=T.CHEST;}});if(isMerchantFloor&&sh.length>2){const mr=sh[Math.floor(sh.length/2)];if(tiles[mr.cy][mr.cx]===T.FLOOR)tiles[mr.cy][mr.cx]=T.MERCHANT;}const numR=Math.min(3,1+(f/4|0));sh.slice(1).forEach(r=>{const n=rnd(1,numR);for(let i=0;i<n&&enemies.length<28;i++){const ex=r.x+rnd(0,r.w-1),ey=r.y+rnd(0,r.h-1);if(tiles[ey]?.[ex]===T.FLOOR)enemies.push({...mkEnemy(f),x:ex,y:ey});}});const items=[];sh.slice(1).forEach(r=>{if(Math.random()<0.2){const ix=r.x+rnd(0,r.w-1),iy=r.y+rnd(0,r.h-1);if(tiles[iy]?.[ix]===T.FLOOR)items.push({...mkItem(f),x:ix,y:iy});}});const merchantInv=isMerchantFloor?Array.from({length:4},()=>mkItem(f+2)):[];return{tiles,vis,rooms,enemies,items,start:{x:sr.cx,y:sr.cy},isBossFloor,isMerchantFloor,merchantInv};}
