    ctx.fillStyle='#fff';ctx.fillRect(bx+s*.34,by+s*.17,2,2);ctx.fillRect(bx+s*.56,by+s*.17,2,2);
    ctx.fillStyle='#8B6914';ctx.fillRect(bx+s*.35,by+s*.18,1.5,1.5);ctx.fillRect(bx+s*.57,by+s*.18,1.5,1.5);
    ctx.fillStyle='rgba(60,100,30,0.6)';ctx.fillRect(bx+s*.35,by+s*.17,1,1);ctx.fillRect(bx+s*.57,by+s*.17,1,1);
